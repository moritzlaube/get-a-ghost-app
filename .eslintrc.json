{
  "env": {
    "browser": true,
    "es2020": true,
    "commonjs": true,
    "node": true
  },
  "extends": ["airbnb-base", "plugin:vue/essential", "prettier"],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "plugins": ["vue"],
  "rules": {
    "eqeqeq": "off",
    "class-methods-use-this": "off"
  }
}
